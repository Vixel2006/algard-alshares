{
  "name": "securepatch",
  "displayName": "SecurePatch",
  "description": "AI-powered security vulnerability patching",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "securepatch.scan",
        "title": "SecurePatch: Scan Workspace"
      },
      {
        "command": "securepatch.healthCheck",
        "title": "SecurePatch: Check Backend Health"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "securepatch-explorer",
          "title": "SecurePatch",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "securepatch-explorer": [
        {
          "type": "webview",
          "id": "securepatch.sidebar",
          "name": "Scan Results",
          "icon": "media/icon.png"
        }
      ]
    },
    "configuration": {
      "title": "SecurePatch",
      "properties": {
        "securepatch.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the SecurePatch backend server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "axios": "^1.6.2"
  }
}